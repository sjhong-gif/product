.magazine-page .chapter__solo-img-inner img { width: 100%; height: 100%; object-fit: cover; }

/* solo-img 가로 스와이프 슬라이더 */
.magazine-page .chapter__solo-img .swiper { position: relative; width: 100%; overflow: hidden; }
.magazine-page .chapter__solo-img .swiper-slide { width: 100%; height: 790px; background: var(--c-placeholder); }
.magazine-page .chapter__solo-img .swiper-slide img { width: 100%; height: 100%; object-fit: cover; }

/* 페이지네이션 — 이미지 하단 안쪽에 오버레이 */
.magazine-page .chapter__solo-img .swiper-pagination {
